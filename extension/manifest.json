{
  "manifest_version": 3,
  "name": "SuperNova TryOnMe - Universal Virtual Try-On",
  "version": "1.1.0",
  "description": "Virtual try-on experience for clothing, shoes, and cosmetics on Amazon, Shein, Temu, and Google Shopping — powered by Amazon Nova AI.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://*.shein.com/*",
    "https://www.temu.com/*",
    "https://shopping.google.com/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/gp/product/*",
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.co.uk/*/dp/*",
        "https://www.amazon.co.uk/gp/product/*"
      ],
      "js": [
        "utils/amazon-scraper.js",
        "utils/image-utils.js",
        "utils/api-client.js",
        "content.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.shein.com/*-p-*.html*",
        "https://*.shein.com/product-*"
      ],
      "js": [
        "utils/shein-scraper.js",
        "utils/image-utils.js",
        "utils/api-client.js",
        "content.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.temu.com/*-g-*.html*",
        "https://www.temu.com/goods-detail*"
      ],
      "js": [
        "utils/temu-scraper.js",
        "utils/image-utils.js",
        "utils/api-client.js",
        "content.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://shopping.google.com/*",
        "https://www.google.com/search*"
      ],
      "js": [
        "utils/google-shopping-scraper.js",
        "utils/image-utils.js",
        "utils/api-client.js",
        "content-gshopping.js"
      ],
      "css": [
        "styles/content.css",
        "styles/gshopping.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "smart-search/results.html",
        "smart-search/results.css",
        "smart-search/results.js",
        "outfit-builder/wardrobe.html",
        "outfit-builder/wardrobe.css",
        "outfit-builder/wardrobe.js",
        "voice-agent/voice.html",
        "voice-agent/voice.css",
        "voice-agent/voice.js",
        "voice-agent/socket.io.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
