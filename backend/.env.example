# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=optional_session_token

# S3 Bucket for Nova Reel video output
S3_BUCKET=nova-tryonme-videos

# S3 Bucket for user photos and favorites
S3_USER_BUCKET=nova-tryonme-users

# Amazon Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# DynamoDB Tables (optional, defaults shown)
DYNAMODB_PROFILES_TABLE=NovaTryOnMe_UserProfiles
DYNAMODB_FAVORITES_TABLE=NovaTryOnMe_Favorites

# Server Configuration
PORT=3000
